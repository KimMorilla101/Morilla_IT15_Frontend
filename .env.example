# Optional: OpenWeather API key. If omitted, app uses Open-Meteo fallback.
VITE_OPENWEATHER_API_KEY=your_openweather_api_key

# Optional: default city for first weather load
VITE_DEFAULT_WEATHER_CITY=Manila

# Optional: enable remote dashboard API (otherwise mock data is used)
VITE_USE_REMOTE_DASHBOARD=true
VITE_API_BASE_URL=https://localhost/morilla_backend/api
